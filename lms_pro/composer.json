{
    "name": "lms/pro",
    "description": "A comprehensive Learning Management System with AI features.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Jules",
            "email": "jules@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "vlucas/phpdotenv": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "LmsPro\\": "lms_pro/"
        },
        "files": [
            "lms_pro/core/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}