# LMS Pro Environment Configuration
# Copy this file to .env and update the values

# Application
APP_NAME="LMS Pro"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=your-secret-key-here
APP_TIMEZONE=UTC
APP_LOCALE=en

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lms_pro
DB_USERNAME=root
DB_PASSWORD=
DB_PREFIX=

# Cache
CACHE_DRIVER=file
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

# Mail
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@lmspro.com
MAIL_FROM_NAME="${APP_NAME}"

# File Storage
FILESYSTEM_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=

# Payment Gateways
PAYMENT_GATEWAY=stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# AI/ML Configuration
TENSORFLOW_ENABLED=true
TENSORFLOW_API_URL=http://localhost:8501
TENSORFLOW_TIMEOUT=30
TENSORFLOW_MEMORY_LIMIT=2G
TENSORFLOW_GPU_ENABLED=false

OPENCV_ENABLED=true
OPENCV_PATH=/usr/local/lib
OPENCV_CASCADE_PATH=/usr/share/opencv4/haarcascades

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30

HUGGINGFACE_ENABLED=false
HUGGINGFACE_API_KEY=
HUGGINGFACE_TIMEOUT=30

SKLEARN_ENABLED=true
NLP_ENABLED=true
CV_ENABLED=true
DL_ENABLED=true
PYTORCH_ENABLED=false

DL_BATCH_SIZE=32
DL_EPOCHS=100
DL_LEARNING_RATE=0.001
DL_VALIDATION_SPLIT=0.2

RECOMMENDATION_ENABLED=true
AUTO_ML_ENABLED=false
FEDERATED_LEARNING_ENABLED=false
QUANTUM_ML_ENABLED=false
EXPLAINABLE_AI_ENABLED=false

AI_MONITORING_ENABLED=true
AI_MODELS_S3_BUCKET=
DATASETS_S3_BUCKET=

# Video Streaming
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=
VIMEO_ACCESS_TOKEN=

YOUTUBE_API_KEY=

ZOOM_API_KEY=
ZOOM_API_SECRET=

# Security
ENCRYPTION_KEY=your-encryption-key-here
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=3600
TWO_FACTOR_ENABLED=false

# API
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=60

# Logging
LOG_CHANNEL=file
LOG_LEVEL=info

# Notifications
FIREBASE_SERVER_KEY=

# Course Settings
MAX_UPLOAD_SIZE=100M
MAX_STUDENTS_PER_COURSE=1000

# Python Path (for AI/ML)
PYTHON_PATH=/usr/bin/python3

# System Maintenance
MAINTENANCE_MODE=false